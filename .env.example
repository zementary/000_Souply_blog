# Copy to .env and fill in as needed. Do not commit .env.

# HTTP/HTTPS proxy for ingest scripts (e.g. yt-dlp, fetch).
# If unset, no proxy is used (silent skip).
# Example: http://127.0.0.1:7897
HTTPS_PROXY=

# Path to cookies file for yt-dlp (e.g. Netscape cookies.txt).
# If unset, falls back to project root "cookies.txt".
BRAVE_COOKIE_PATH=
